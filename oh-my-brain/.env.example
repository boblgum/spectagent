# ── OpenMemory stack – environment variables ──────────────────────────────────
# Copy this file:
#   cp oh-my-brain/.env.example oh-my-brain/.env
# Then fill in the values below.
#
# OPENAI_API_KEY is read from the existing secrets/ pattern:
#   echo -n "sk-…" > secrets/openai_api_key.txt && chmod 600 secrets/openai_api_key.txt
# The value is injected into the openmemory-mcp container at runtime (see docker-compose.yml).

# ── LLM / Embeddings ──────────────────────────────────────────────────────────
# Required by openmemory-mcp for memory extraction and vector embeddings.
# Leave blank here – supply via  secrets/openai_api_key.txt  instead.
OPENAI_API_KEY=

# ── Custom OpenAI-compatible provider (Option A) ──────────────────────────────
# Set OPENAI_BASE_URL to redirect all LLM + embedder calls to any OpenAI-
# compatible endpoint (Ollama, LM Studio, vLLM, Azure, OpenRouter, …).
# Leave blank to use the official OpenAI API.
OPENAI_BASE_URL=
# Alias recognised by older versions of the openai-python SDK (≤ 0.x).
OPENAI_API_BASE=

# ── Memory namespace ──────────────────────────────────────────────────────────
# Used as the default user_id for memories stored by openmemory-mcp.
# Defaults to your OS username if left blank.
USER=

# ── Ports ─────────────────────────────────────────────────────────────────────
# Host port for the OpenMemory API + MCP server (container port 8765).
OPENMEMORY_API_PORT=8765

# Host port for the optional OpenMemory UI (container port 3000).
OPENMEMORY_UI_PORT=3000

