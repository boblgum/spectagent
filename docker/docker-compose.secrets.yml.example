# ── User-defined secrets ──────────────────────────────────────────────
# Copy this file:
#   cp docker/docker-compose.secrets.yml.example docker/docker-compose.secrets.yml
#
# Then uncomment / add only the secrets you actually need.
# Each secret points to a plain-text file under secrets/ (one key per file).
# The entrypoint automatically exports every mounted secret as an
# upper-cased environment variable  (e.g.  anthropic_api_key → ANTHROPIC_API_KEY).
#
# To add a new secret:
#   1. Create  secrets/<name>.txt  with the key value (chmod 600).
#   2. Add a top-level entry under  secrets:  below.
#   3. Reference it under  services.spectagent.secrets:
#
# ── oh-my-opencode provider notes ────────────────────────────────────
#   anthropic_api_key   → ANTHROPIC_API_KEY   (Claude — direct API key, alternative to OAuth)
#   openai_api_key      → OPENAI_API_KEY      (ChatGPT Plus / GPT-5.x)
#   gemini_api_key      → GEMINI_API_KEY      (Google Gemini — direct API key)
#   github_token        → GITHUB_TOKEN        (GitHub Copilot OAuth token)
#   zai_api_key         → ZAI_API_KEY         (Z.ai Coding Plan)
#   opencode_api_key    → OPENCODE_API_KEY    (OpenCode Zen subscription)

services:
  spectagent:
    secrets: []
      # ── Native providers (highest priority) ──
      # - anthropic_api_key
      # - openai_api_key
      # - gemini_api_key
      # ── Fallback providers ────────────────────
      # - github_token
      # - zai_api_key
      # - opencode_api_key

# secrets:
  # anthropic_api_key:
  #   file: ../secrets/anthropic_api_key.txt
  # openai_api_key:
  #   file: ../secrets/openai_api_key.txt
  # gemini_api_key:
  #   file: ../secrets/gemini_api_key.txt
  # github_token:
  #   file: ../secrets/github_token.txt
  # zai_api_key:
  #   file: ../secrets/zai_api_key.txt
  # opencode_api_key:
  #   file: ../secrets/opencode_api_key.txt
