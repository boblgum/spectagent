# ── Host paths ────────────────────────────────────────────────────────
# App / workspace directory (created automatically if it does not exist)
APP_DIR=../workspace

# opencode configuration directory (must contain opencode.json if customised)
OPENCODE_CONFIG_DIR=../config/opencode

# Git global config file
GIT_CONFIG_FILE=../config/git/.gitconfig

# oh-my-opencode subscription flags (populated by  make omc-setup)
# This line is written automatically — do not edit by hand.
OMC_FLAGS=

# ── API keys are managed via Docker secrets ───────────────────────────
# Each user defines their own secrets in docker/docker-compose.secrets.yml
# (see docker/docker-compose.secrets.yml.example).
# Run  make secrets  to create the file from the template.

